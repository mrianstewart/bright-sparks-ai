{
  "framework": "nextjs",
  "installCommand": "cd .. && npm install",
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/roast-machine",
      "destination": "https://roast-machine-mu.vercel.app/roast-machine"
    },
    {
      "source": "/roast-machine/(.*)",
      "destination": "https://roast-machine-mu.vercel.app/roast-machine/$1"
    },
    {
      "source": "/magic-todo",
      "destination": "https://magic-todo-two.vercel.app/magic-todo"
    },
    {
      "source": "/magic-todo/(.*)",
      "destination": "https://magic-todo-two.vercel.app/magic-todo/$1"
    },
    {
      "source": "/speech-writer",
      "destination": "https://speech-writer-cyan.vercel.app/speech-writer"
    },
    {
      "source": "/speech-writer/(.*)",
      "destination": "https://speech-writer-cyan.vercel.app/speech-writer/$1"
    }
  ]
}
